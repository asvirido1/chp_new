# Скопируй в .env в ЭТОМ каталоге (artifacts/app) — Expo подхватит при старте.
# Секреты сюда не клади; для продакена используй EAS Secrets / CI.

# Локальный API (HTTP):
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8080

# Или только хост (будет https://HOST — для локали не подойдёт без HTTPS):
# EXPO_PUBLIC_API_HOST=api.example.com

# Старое имя (как EXPO_PUBLIC_API_HOST):
# EXPO_PUBLIC_DOMAIN=api.example.com

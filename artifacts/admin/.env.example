# Опционально: скопируй в .env в этом каталоге — Vite подхватит при `pnpm dev`.
# Куда проксировать /api в dev и `vite preview` (по умолчанию http://127.0.0.1:8080).
# ADMIN_DEV_API_ORIGIN=http://127.0.0.1:8080

# Включает client-side guard для staging/dev admin UI.
# Секрет в client bundle НЕ хранится: пользователь вводит его вручную,
# а UI сохраняет его только в sessionStorage.
# VITE_ADMIN_GUARD_ENABLED=true
# VITE_ADMIN_GUARD_TITLE=CHPOK Admin

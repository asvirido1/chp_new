# =============================================================================
# Chpok — переменные окружения (шаблон, без секретов)
#
# Monorepo не подхватывает один корневой .env для всех пакетов автоматически.
# Важно: backend на Node.js сейчас НЕ читает .env сам по себе.
# Для backend задавай переменные в shell / панели хостинга или сначала source
# локального env-файла вручную. Vite/Expo свои .env умеют читать сами.
# =============================================================================

# ---------------------------------------------------------------------------
# ЗОНА: shared / build-time (несколько пакетов)
# ---------------------------------------------------------------------------
# NODE_ENV     — production | development (Node/Vite/Metro; влияет на дефолт PORT API)
# CI           — выставляется в .replit postBuild; для локали обычно не нужен
# PORT         — ОДНО ИМЯ, РАЗНЫЕ ПРОЦЕССЫ: у каждого запущенного сервиса свой PORT
#                в своём терминале (API 8080, admin 5173, landing 5174, …).
# BASE_PATH    — префикс публичного URL для Vite (часто "/"; для подпути — "/admin/")

# ---------------------------------------------------------------------------
# ЗОНА: backend / @workspace/api-server + @workspace/db
# ---------------------------------------------------------------------------
# Обязательно для БД и API:
# Для локального запуска против Supabase в текущем окружении рабочим оказался
# session pooler, а не direct host. Для Node/pg здесь также понадобился
# sslmode=no-verify.
# Формат:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=no-verify
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# API слушает PORT. Локально: если NODE_ENV не production, по умолчанию 8080.
# В production PORT должен быть задан явно.
PORT=8080

# Необязательно:
# LOG_LEVEL=info
#
# Для staging/dev media upload в Supabase Storage:
# SUPABASE_URL=https://PROJECT_REF.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# SUPABASE_STORAGE_BUCKET=report-media
#
# Для staging/dev admin guard:
# ADMIN_SECRET=replace-with-a-long-random-string
#
# Для Supabase Edge Function и voice-to-text через Fireworks:
# FIREWORKS_API_KEY=fw_...
# SUPABASE_URL=https://PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=sb_publishable_xxx
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ---------------------------------------------------------------------------
# ЗОНА: frontend — Vite (admin, landing, mockup-sandbox)
# ---------------------------------------------------------------------------
# Дефолты в vite.config: admin 5173, landing 5174, mockup-sandbox 5175, BASE_PATH="/".
# Переопредели при конфликте портов или нестандартном base:
# PORT=5173
# BASE_PATH=/

# --- admin (@workspace/admin) только dev/preview ---
# Запросы к /api/* с dev-сервера проксируются на Express (по умолчанию 127.0.0.1:8080).
# Если API на другом origin/port:
# ADMIN_DEV_API_ORIGIN=http://127.0.0.1:9090
#
# Сборка (vite build): статика по-прежнему дергает относительные /api/* — на хостинге
# нужен общий reverse proxy или тот же origin, что и у API.

# landing / mockup-sandbox: прокси к API не настроен; при необходимости — отдельный спринт.

# ---------------------------------------------------------------------------
# ЗОНА: mobile / @workspace/app (Expo, встраиваются на этапе bundle)
# ---------------------------------------------------------------------------
# Рекомендуется полный origin API (локально часто http, прод — https):
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
#
# Для прямого upload/invoke из mobile в Supabase:
# EXPO_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
#
# Для voice upload в приватный bucket также нужен включённый Anonymous Auth
# в Supabase и storage policy на префикс:
# voice-notes/<auth.uid()>/...

# Альтернатива: только host[:port] — клиент соберёт https://<host>/...
# (для локального HTTP используй EXPO_PUBLIC_API_BASE_URL).
# EXPO_PUBLIC_API_HOST=api.example.com

# Устаревшее имя, то же поведение, что EXPO_PUBLIC_API_HOST (HTTPS):
# EXPO_PUBLIC_DOMAIN=api.example.com

# Необязательно (веб-сборка / Replit):
# EXPO_PUBLIC_REPL_ID=

# ---------------------------------------------------------------------------
# Replit-only (вне Replit не задавать)
# ---------------------------------------------------------------------------
# REPLIT_DEV_DOMAIN
# REPLIT_EXPO_DEV_DOMAIN
# REPLIT_INTERNAL_APP_DOMAIN
# REPL_ID
# EXPO_PACKAGER_PROXY_URL
# REACT_NATIVE_PACKAGER_HOSTNAME

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Достаточно подставить Postgres connection string в DATABASE_URL.
# Для ЧПОК локально уже подтвердился session pooler path:
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=no-verify
# Direct host db.<project-ref>.supabase.co в этом окружении локально не заработал.
# Для Edge Function нужны как минимум:
# FIREWORKS_API_KEY
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
